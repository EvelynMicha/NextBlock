<!DOCTYPE html>
<html>
  <head>
    <% if (htmlWebpackPlugin.options.gtm_id) { %>
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl+'<%= htmlWebpackPlugin.options.gtm_env_auth %>';
        f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','<%- htmlWebpackPlugin.options.gtm_id %>');
    </script>
    <!-- End Google Tag Manager -->
    <% } %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="google" value="notranslate">
    <link rel="shortcut icon" href="static/favicon.ico">
    <title><%= htmlWebpackPlugin.options.title %></title>

    <!-- Hard override to neutralize any accidental color filters/time‑travel tints -->
    <style id="nextblock-filter-reset">
      html, body, #app, .app, .page-wrapper, .body-wrapper, .stage-wrapper, .stage, .stage-canvas-wrapper, .target-pane, .sprite-selector, .sprite-selector-scroll-outer {
        filter: none !important;
        -webkit-filter: none !important;
      }
      body { background: #E5F0FF !important; }
      .stage-wrapper, .stage-canvas-wrapper, .stage { background: #FFFFFF !important; }
      .sprite-selector, .target-pane { background: #E9F1FC !important; }
    </style>

    <script>
      (function () {
        const clearFilter = () => {
          const doc = document.documentElement;
          if (!doc) return;
          if (doc.style && doc.style.filter) doc.style.filter = '';
          if (doc.style && doc.style.height === '100%') doc.style.height = '';
        };
        clearFilter();
        const mo = new MutationObserver(clearFilter);
        mo.observe(document.documentElement, {attributes: true, attributeFilter: ['style']});
        window.addEventListener('load', clearFilter);
      })();
    </script>
  </head>
  <body>
    <% if (htmlWebpackPlugin.options.gtm_id) { %>
      <!-- Google Tag Manager (noscript) -->
      <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=<%- htmlWebpackPlugin.options.gtm_id %><%= htmlWebpackPlugin.options.gtm_env_auth %>" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
      <!-- End Google Tag Manager (noscript) -->
    <% } %>
  </body>
</html>
